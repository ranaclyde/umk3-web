---
// 4:3 container with CRT scanlines and vignette
---
<div class="retro-wrapper">
  <slot />
</div>

<style>
  .retro-wrapper {
    position: relative;
    width: 100%;
    max-width: 960px;
    max-height: 100dvh;
    aspect-ratio: 4 / 3;
    margin: 0 auto;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(241, 196, 15, 0.06),
      0 0 40px rgba(0, 0, 0, 0.9),
      0 0 120px rgba(0, 0, 0, 0.6);
    background-color: rgba(73, 73, 73, 0.8);
  }

  /* Portrait mobile: fill the full viewport */
  @media (max-width: 640px) and (orientation: portrait) {
    .retro-wrapper {
      max-width: none;
      max-height: none;
      width: 100%;
      height: 100dvh;
      height: 100vh; /* fallback */
      aspect-ratio: unset;
    }
  }

  /* Vignette — slightly deeper at edges */
  .retro-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 998;
  }

  /* CRT scanlines */
  .retro-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 999;
  }
</style>
